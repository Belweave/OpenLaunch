# Ollama URL for the backend to connect
# The path '/ollama' will be redirected to the specified backend URL
OLLAMA_BASE_URL='http://localhost:11434'

OPENAI_API_BASE_URL=''
OPENAI_API_KEY=''

# Anthropic defaults to https://api.anthropic.com/v1. Override the base URL
# only for an Anthropic Messages API-compatible endpoint.
ANTHROPIC_API_BASE_URL='https://api.anthropic.com/v1'
ANTHROPIC_API_KEY=''

# AUTOMATIC1111_BASE_URL="http://localhost:7860"

# For production, you should only need one host as
# fastapi serves the svelte-kit built frontend and backend from the same host and port.
# To test with CORS locally, you can set something like
# CORS_ALLOW_ORIGIN='http://localhost:5173;http://localhost:8080'
CORS_ALLOW_ORIGIN='*'

# Set to false to keep memory tools enabled without adding memory context to the system context.
ENABLE_MEMORY_SYSTEM_CONTEXT=true

# Optional named, read-only data sources for native agent tool calling.
# Prefer a secret-mounted JSON file. Connections without access_grants are admin-only.
ENABLE_DATA_SOURCE_TOOLS=false
DATA_SOURCE_CONNECTIONS='[]'
DATA_SOURCE_CONNECTIONS_FILE=''
DATA_SOURCE_MAX_ROWS=200
DATA_SOURCE_QUERY_TIMEOUT_SECONDS=15
DATA_SOURCE_MAX_RESULT_BYTES=100000
DATA_SOURCE_MAX_QUERY_CHARACTERS=20000
# Keep false globally and grant features.data_sources only to approved groups.
USER_PERMISSIONS_FEATURES_DATA_SOURCES=false

# Legacy single-PostgreSQL settings remain supported for upgrades.
ENABLE_SQL_DATABASE_TOOL=false
SQL_DATABASE_URL=''

# For production you should set this to match the proxy configuration (127.0.0.1)
FORWARDED_ALLOW_IPS='*'

# DO NOT TRACK
SCARF_NO_ANALYTICS=true
DO_NOT_TRACK=true
ANONYMIZED_TELEMETRY=false

# Valkey Vector Store (requires VECTOR_DB=valkey)
# VALKEY_URL='valkey://localhost:6379'
# VALKEY_COLLECTION_PREFIX='openlaunch'
# VALKEY_INDEX_TYPE='HNSW'
# VALKEY_DISTANCE_METRIC='COSINE'
# VALKEY_HNSW_M='16'
# VALKEY_HNSW_EF_CONSTRUCTION='200'
# VALKEY_HNSW_EF_RUNTIME='10'
